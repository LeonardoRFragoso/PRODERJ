# Z.ai API Configuration (server-side only)
# Copy this file to .env.local and fill with real values
# NEVER commit .env.local or any file with real API keys

ZAI_API_KEY=your_zai_api_key_here
ZAI_BASE_URL=https://api.z.ai/api/paas/v4
# Free tier: glm-4.5-flash (1000 req/day, 3 req/min)
# Paid: glm-5.1, glm-4.7, glm-5.2
ZAI_MODEL=glm-4.5-flash

# Admin token to protect AI generation endpoints (server-side only)
# Required: /api/generate-questions and /api/review-question will return 401 without this
# Generate with: openssl rand -base64 48
AI_ADMIN_TOKEN=your-admin-token-here

# Frontend flag to show AI generator panel (no secrets here)
VITE_ENABLE_AI_GENERATOR=false
